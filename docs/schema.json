{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ruleman.dev/schema.json",
  "title": "ruleman configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Points editors at this schema for autocomplete/validation."
    },
    "extends": {
      "type": "array",
      "description": "Other ruleman config files to inherit rules from, resolved relative to this file.",
      "items": { "type": "string" }
    },
    "rules": {
      "type": "array",
      "description": "The checks to run, in order.",
      "items": { "$ref": "#/definitions/rule" }
    }
  },
  "definitions": {
    "severity": {
      "type": "string",
      "enum": ["error", "warn", "off"],
      "default": "error"
    },
    "rule": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "files"],
          "properties": {
            "type": { "const": "file" },
            "severity": { "$ref": "#/definitions/severity" },
            "state": {
              "type": "string",
              "enum": ["present", "absent"],
              "default": "present",
              "description": "'present' fails if a listed path is missing or is not a regular file; 'absent' fails if anything exists there."
            },
            "files": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Files to check, relative to the config file."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "directories"],
          "properties": {
            "type": { "const": "directory" },
            "severity": { "$ref": "#/definitions/severity" },
            "state": {
              "type": "string",
              "enum": ["present", "absent"],
              "default": "present",
              "description": "'present' fails if a listed path is missing or is not a directory; 'absent' fails if anything exists there."
            },
            "empty": {
              "type": "boolean",
              "description": "If set, additionally requires zero (true) or at least one (false) entries. Only checked when state is 'present'."
            },
            "directories": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Directories to check, relative to the config file."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "file", "key", "expected"],
          "properties": {
            "type": { "const": "content" },
            "severity": { "$ref": "#/definitions/severity" },
            "format": {
              "type": "string",
              "enum": ["json"],
              "default": "json",
              "description": "Parser to use for the file. yaml/toml are planned."
            },
            "state": {
              "type": "string",
              "enum": ["match", "mismatch"],
              "default": "match",
              "description": "'match' requires the key to equal `expected`; 'mismatch' requires it not to."
            },
            "file": { "type": "string", "description": "Path to the file." },
            "key": { "type": "string", "description": "Dot-separated path into the parsed document." },
            "expected": { "description": "The value `key` is compared against." }
          }
        }
      ]
    }
  }
}
